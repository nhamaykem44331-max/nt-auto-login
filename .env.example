NAMTHANH_USERNAME= # Tên đăng nhập booking.namthanh.vn; mặc định: rỗng; override khi đổi tài khoản agent.
NAMTHANH_PASSWORD= # Mật khẩu booking.namthanh.vn; mặc định: rỗng; override khi cập nhật thông tin đăng nhập.
NAMTHANH_AGENCY_CODE= # Mã đại lý Nam Thanh; mặc định: rỗng; override khi dùng agency khác.

DDDDOCR_API_URL=http://localhost:8001 # Endpoint OCR captcha; mặc định: http://localhost:8001; override khi OCR chạy trên máy/port khác.
HEADLESS=false # Bật/tắt Playwright headless; mặc định: false; override khi chạy server không có màn hình.
SCREENSHOT_DIR=./screenshots # Thư mục lưu screenshot debug; mặc định: ./screenshots; override khi muốn đổi nơi lưu file.
SESSION_FILE=./session/storage-state.json # File session localStorage; mặc định: ./session/storage-state.json; override khi tách session theo môi trường.
LOGIN_SKIP_SCREENSHOTS=true # Bỏ qua screenshot happy-path login; mặc định: true; override khi cần chụp ảnh để debug login.

MUADI_SEARCH_TIMEOUT_MS=25000 # Timeout cho search/price Muadi (ms); prompt backend stream dùng 25000 để fail-fast airline chậm.
CREATE_BOOKING_TIMEOUT_MS=150000 # Timeout cho create-booking Muadi (ms); mặc định: 150000; override khi giữ chỗ thật cần chờ lâu hơn.
MUADI_RETRY_MAX_ATTEMPTS=3 # Số lần retry request retryable tối đa; mặc định: 3; override khi muốn giảm/tăng độ bền.
MUADI_RETRY_BASE_DELAY_MS=500 # Delay backoff ban đầu cho retry Muadi (ms); mặc định: 500; override khi cần retry gấp hơn/chậm hơn.
MUADI_RETRY_MAX_DELAY_MS=5000 # Trần delay backoff Muadi (ms); mặc định: 5000; override khi cần giới hạn độ trễ retry.
MUADI_AES_KEY= # Khóa AES-128-CBC cho Muadi, dùng 16 bytes; mặc định: rỗng; override khi đã được cấp credential thật.
MUADI_AES_IV= # IV AES-128-CBC cho Muadi, dùng 16 bytes; mặc định: rỗng; override khi đã được cấp credential thật.

LOG_LEVEL=info # Mức độ log (debug/info/warn/error); mặc định: info; override khi cần log chi tiết hơn.
MASK_PII=true # Che thông tin nhạy cảm trong log; mặc định: true; override false chỉ khi debug local có kiểm soát.

BACKEND_PORT=3100 # Port HTTP backend ưu tiên; mặc định: 3100; override khi port 3100 bị chiếm.
PORT=3100 # Port fallback nếu BACKEND_PORT không set; mặc định: 3100; override khi deploy theo convention hosting.
SEARCH_CACHE_TTL_SECONDS=900 # TTL cache search (giây); mặc định: 900; override khi muốn cache ngắn/dài hơn.
SEARCH_RESPONSE_CACHE_TTL_SECONDS=90 # TTL cache response /flights/search (giây); search giống nhau trả ngay trong TTL.
BOOKING_CACHE_TTL_SECONDS=3600 # TTL cache booking/hold (giây); mặc định: 3600; override khi cần giữ response ngắn/dài hơn.
BACKEND_API_KEY= # API key bảo vệ hệ thống backend HTTP; mặc định: rỗng; override bắt buộc khi expose ngoài localhost.
API_SECRET_KEY= # Alias cũ cho BACKEND_API_KEY; mặc định: rỗng; override chỉ khi cần tương thích env cũ.
BACKEND_ALLOW_NO_AUTH=false # Cho phép gọi backend không cần API key; mặc định: false; override true chỉ cho local dev.
BACKEND_CORS_ORIGIN=* # Danh sách origin được phép, cách nhau bằng dấu phẩy; mặc định: *; override khi cần khóa CORS.
BACKEND_EXPOSE_ERROR_DETAILS= # Hiện chi tiết lỗi ra response; mặc định: true khi NODE_ENV != production, ngược lại false; override khi cần debug production có kiểm soát.
BACKEND_WARMUP=true # Tự động warm-up session khi boot server; mặc định: true; override false khi không muốn login nền.

EXCHANGE_RATE_TTL_SECONDS=300 # TTL cache tỷ giá (giây); mặc định: 300; override khi cần refresh thường xuyên hơn.
EXCHANGE_RATE_FALLBACK=26357 # Tỷ giá dự phòng khi API tỷ giá lỗi; mặc định: 26357; override khi muốn cập nhật số fallback.

TOKEN_REFRESH_LEAD_MS=120000 # Số ms làm sớm trước khi refresh token; mặc định: 120000; override khi token hết hạn nhanh/chậm hơn.
TOKEN_REFRESH_MIN_DELAY_MS=5000 # Delay tối thiểu giữa lúc lên lịch và refresh token (ms); mặc định: 5000; override khi cần phân tán retry.
TOKEN_REFRESH_MAX_DELAY_MS=3600000 # Delay tối đa cho lịch refresh token (ms); mặc định: 3600000; override khi cần giới hạn lại.
SESSION_ENSURE_MIN_TTL_SEC=120 # TTL tối thiểu của session để xem là còn ấm (giây); mặc định: 120; override khi muốn warm-up sớm hơn.

HOLD_PRICING_TICKETINFO_ATTEMPTS=3 # Số lần retry pricing qua booking/ticket-info-by-id; mặc định: 3; override khi cần đổi độ bền/tốc độ.
HOLD_PRICING_TICKETINFO_INITIAL_DELAY_MS=250 # Delay ban đầu giữa các lần retry ticket-info (ms); mặc định: 250; override khi cần retry nhanh/chậm hơn.
HOLD_PRICING_FALLBACK_ATTEMPTS=2 # Số lần retry fallback qua management/list-booking; mặc định: 2; override khi fallback cần chờ thêm.
HOLD_PRICING_FALLBACK_INITIAL_DELAY_MS=300 # Delay ban đầu cho fallback pricing (ms); mặc định: 300; override khi cần retry nhanh/chậm hơn.
HOLD_PRICING_SYNC_ATTEMPTS=2 # Alias cũ cho HOLD_PRICING_FALLBACK_ATTEMPTS; mặc định: 2 nếu fallback env mới không set; override để tương thích env cũ.
HOLD_PRICING_SYNC_INITIAL_DELAY_MS=300 # Alias cũ cho HOLD_PRICING_FALLBACK_INITIAL_DELAY_MS; mặc định: 300 nếu fallback env mới không set; override để tương thích env cũ.

VALIDATION_RETRY_DELAY_MS=700 # Delay retry khi verify protection cần thử lại (ms); mặc định: 700; override khi Muadi trả validation chậm.
POLL_MAX_ATTEMPTS=10 # Số lần poll ticket-info sau create-booking; mặc định: 10; override khi cần poll ngắn/dài hơn.
POLL_MAX_WALL_CLOCK_MS=30000 # Giới hạn tổng thời gian poll ticket-info (ms); mặc định: 30000; override khi cần fail-fast hoặc chờ lâu hơn.
POLL_CIRCUIT_BREAKER_THRESHOLD=3 # Số lỗi liên tiếp để cắt poll ticket-info; mặc định: 3; override khi muốn khoan dung hơn.

NODE_ENV=development # Môi trường chạy Node; mặc định: giá trị Node cung cấp, nếu không có sẽ khiến backend expose detail ngoài production; override khi deploy.

NAMTHANH_BACKEND_URL=http://localhost:3100 # URL backend local cho frontend/script; mặc định: http://localhost:3100; override khi backend đổi host hoặc port.
NAMTHANH_BACKEND_API_KEY= # API key client dùng để gọi backend; mặc định: rỗng; override bằng cùng giá trị BACKEND_API_KEY khi frontend không chạy cùng host.
